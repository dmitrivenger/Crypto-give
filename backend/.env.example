NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cryptogive_dev

# Blockchain
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key

# CoinGecko
COINGECKO_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_KEY=change_me_to_a_strong_secret

# Blockchain settings
ETHEREUM_CONFIRMATIONS_REQUIRED=12
POLYGON_CONFIRMATIONS_REQUIRED=128
BLOCKCHAIN_POLL_INTERVAL_MS=30000
